{
  "name": "expense-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "vercel-build": "npm run build:prisma && npm run build:client",
    "build:prisma": "prisma generate --schema=server/prisma/schema.prisma",
    "build:client": "cd client && npm install && npm run build",
    "postinstall": "prisma generate --schema=server/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
